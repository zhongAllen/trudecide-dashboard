# ============================================================
# Trudecide 股票版 - 环境变量配置模板
# 请将此文件复制为 .env，并填入你的实际凭证
# 警告：.env 文件包含敏感凭证，已加入 .gitignore，禁止提交到 Git
# ============================================================

# ── Supabase 配置 ──────────────────────────────────────────
# 项目地址（Project URL），在 Supabase 控制台 -> Settings -> API 获取
SUPABASE_URL=""

# 服务端密钥（service_role Key），在 Supabase 控制台 -> Settings -> API 获取
# 仅用于后端/数据采集脚本，拥有完整读写权限，请勿泄露
SUPABASE_SERVICE_KEY=""

# 匿名公开密钥（anon Key），在 Supabase 控制台 -> Settings -> API 获取
# 用于前端 React 读取数据，受 RLS 策略限制
SUPABASE_ANON_KEY=""

# ── Tushare 配置 ───────────────────────────────────────────
# Tushare Pro Token，在 https://tushare.pro/user/token 获取
# 用于获取个股日度数据、板块成分股、新闻等
TUSHARE_TOKEN=""

# ── AKShare 配置 ───────────────────────────────────────────
# AKShare 无需 API Key，直接 pip install akshare 后使用
# 无需配置任何凭证
